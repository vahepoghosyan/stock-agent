# ── Anthropic Claude API ──────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── NewsAPI ───────────────────────────────────────────────────────
# Free key (100 req/day) at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Gmail ─────────────────────────────────────────────────────────
# Enable 2FA on your Google account, then create an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send the daily report (defaults to GMAIL_USER if not set)
EMAIL_TO=your.email@gmail.com

# ── Schedule ──────────────────────────────────────────────────────
# Time to run daily (24h format, your local timezone)
# Default: 09:00 = 9:00 AM — adjust to run before market open
RUN_TIME=09:00
